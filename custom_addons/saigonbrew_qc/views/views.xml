<odoo>
  <data>
    <record id="view_mrp_production_form_inherit_qc" model="ir.ui.view">
      <field name="name">mrp.production.form.inherit.qc</field>
      <field name="model">mrp.production</field>
      <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
      <field name="arch" type="xml">
        <xpath expr="//sheet/group" position="after">
          <group string="Quality Control">
            <group>
              <field name="brewing_temp"/>
              <field name="qc_passed_by"/>
            </group>
          </group>
        </xpath>
      </field>
    </record>
  </data>
</odoo>